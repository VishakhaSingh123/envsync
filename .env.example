# .env.example — Source of Truth
# Every environment MUST define all keys listed here.
# Use CHANGE_ME as a placeholder for secrets.

# Application
APP_NAME=myapp
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_dev
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# Auth
JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=7d

# Third-party APIs
STRIPE_SECRET_KEY=CHANGE_ME
SENDGRID_API_KEY=CHANGE_ME
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1

# Feature Flags
ENABLE_SIGNUPS=true
ENABLE_PAYMENTS=false
MAINTENANCE_MODE=false
